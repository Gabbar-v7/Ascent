          "sql": "CREATE TABLE IF NOT EXISTS \"tasks\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"description\" TEXT NULL, \"due_date\" INTEGER NOT NULL, \"done_on\" INTEGER NULL, \"notify\" INTEGER NULL CHECK (\"notify\" IN (0, 1)));"
