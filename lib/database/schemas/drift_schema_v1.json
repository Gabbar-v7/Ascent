        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"routines\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"repeat_days_mask\" INTEGER NOT NULL, \"target_count\" INTEGER NOT NULL, \"time_of_day\" INTEGER NOT NULL, \"notify\" INTEGER NOT NULL CHECK (\"notify\" IN (0, 1)), \"reminder_offset_minutes\" INTEGER NOT NULL DEFAULT 0, \"is_archived\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_archived\" IN (0, 1)));"
